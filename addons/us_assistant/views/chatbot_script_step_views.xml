<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="assistant_chatbot_script_step_view_form_inherit" model="ir.ui.view">
        <field name="name">chatbot.script.step.view.form.inherit</field>
        <field name="model">chatbot.script.step</field>
        <field name="inherit_id" ref="im_livechat.chatbot_script_step_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='step_type']" position="after">
                <field name="forward_operator_with_assistant" invisible="step_type != 'forward_operator'"/>
            </xpath>
        </field>
    </record>
</odoo>