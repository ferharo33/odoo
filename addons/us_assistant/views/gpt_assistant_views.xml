<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="gpt_assistant_action" model="ir.actions.act_window">
        <field name="name">Assistants</field>
        <field name="res_model">gpt.assistant</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="gpt_assistant_view_tree" model="ir.ui.view">
        <field name="name">gpt.assistant.tree</field>
        <field name="model">gpt.assistant</field>
        <field name="arch" type="xml">
            <list>
                 <field name="name"/>
                <field name="assistant_id"/>
                <field name="vector_store_id"/>
            </list>
        </field>
    </record>

    <record id="gpt_assistant_view_form" model="ir.ui.view">
        <field name="name">gpt.assistant.form</field>
        <field name="model">gpt.assistant</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="token_api" password="1"/>
                        <field name="assistant_id"/>
                        <field name="vector_store_id" options="{'no_edit': True, 'no_create': True}" placeholder="You can choose a vector store after defining the assistant token"  domain="[('store_key', '=', token_api)]"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
