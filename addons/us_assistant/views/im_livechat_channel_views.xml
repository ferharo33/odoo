<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="assistant_im_livechat_channel_view_form_inherit" model="ir.ui.view">
        <field name="name">im_livechat.channel.form.inherit</field>
        <field name="model">im_livechat.channel</field>
        <field name="inherit_id" ref="im_livechat.im_livechat_channel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Assistant" name="assistants">
                    <group>
                        <field name="assistant_id"/>
                        <field name="is_only_hint_available"/>
                        <field name="responsible_user" domain="[('id','in', user_ids)]"/>
                    </group>
                    <p class="text-muted" colspan="2">
                        You can set the Assistant to communicate with customers in live chat.
                    </p>
                </page>
            </xpath>
        </field>
    </record>
</odoo>