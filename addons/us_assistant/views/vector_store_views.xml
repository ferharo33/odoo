<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="vector_store_action" model="ir.actions.act_window">
        <field name="name">Vector Store</field>
        <field name="res_model">vector.store</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="vector_store_tree" model="ir.ui.view">
        <field name="name">vector.store.tree</field>
        <field name="model">vector.store</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="store_id"/>
            </list>
        </field>
    </record>

    <record id="vector_store_view_form" model="ir.ui.view">
        <field name="name">vector.store.form</field>
        <field name="model">vector.store</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="is_vector_store_odoo" invisible="1"/>
                    <widget
                        name="web_ribbon"
                        text="From Dashboard"
                        bg_color="bg-success"
                        invisible="is_vector_store_odoo"
                    />
                    <group>
                        <field name="store_key" password="True"/>
                        <field name="name"/>
                        <field name="store_id" style="width:50%%" readonly="1" widget="CopyClipboardChar" invisible="not store_id"/>
                    </group>
                    <group>
                        <field name="attachment_ids" widget="many2many_binary" nolabel="1" colspan="2"/>
                    </group>
                    <field name="is_attach_change" invisible="1"/>
                    <button name="upload_file" confirm="Warning! All files from Vector Store will be deleted and the current list of files will be added." string="Upload Files" invisible="not is_attach_change" type="object" class="oe_highlight"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
