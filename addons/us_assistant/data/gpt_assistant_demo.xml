<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="gpt_assistant_1" model="res.partner">
            <field name="name">Assistant</field>
            <field name="is_assistant">True</field>
            <field name="image_1920" type="base64" file="us_assistant/static/description/icon.png"/>
        </record>

        <record id="gpt_demo_partner_1" model="res.partner">
            <field name="name">Vito Scaletta</field>
            <field name="street">17 Baker St.</field>
            <field name="zip">12345</field>
            <field name="city">New York</field>
            <field name="country_id" ref="base.us"/>
            <field name="phone">+1 333-333-3131</field>
            <field name="email">vito@example.com</field>
            <field name="image_1920" type="base64" file="us_assistant/static/description/vito.png"/>
        </record>

        <record id="gpt_assistant_demo_1" model="gpt.assistant">
            <field name="name">Assistant</field>
            <field name="token_api">sdg134g3g35gfg23shy5</field>
            <field name="assistant_id">12345</field>
            <field name="partner_id" ref="gpt_assistant_1"/>
        </record>

        <record id="mail_channel_assistant" model="discuss.channel">
            <field name="name">demo assistant</field>
            <field name="description">Assistant demonstration channel.</field>
            <field name="group_ids" eval="[Command.link(ref('base.group_user'))]"/>
        </record>

        <record id="mail_channel_assistant_partner_1" model="discuss.channel.member">
            <field name="partner_id" ref="gpt_assistant_1"/>
            <field name="channel_id" ref="us_assistant.mail_channel_assistant"/>
        </record>

        <record id="mail_channel_assistant_partner_2" model="discuss.channel.member">
            <field name="partner_id" ref="gpt_demo_partner_1"/>
            <field name="channel_id" ref="us_assistant.mail_channel_assistant"/>
        </record>

<!--        <record id="mail_channel_assistant_partner_3" model="discuss.channel.member">-->
<!--            <field name="partner_id" ref="base.partner_admin"/>-->
<!--            <field name="channel_id" ref="us_assistant.mail_channel_assistant"/>-->
<!--        </record>-->

        <record id="mail_message_1" model="mail.message">
            <field name="model">discuss.channel</field>
            <field name="message_type">comment</field>
            <field name="res_id" ref="us_assistant.mail_channel_assistant"/>
            <field name="body"><![CDATA[<p>Hello</p>]]></field>
            <field name="author_id" ref="gpt_demo_partner_1"/>
            <field name="subtype_id" ref="mail.mt_comment"/>
        </record>

        <record id="mail_message_2" model="mail.message">
            <field name="model">discuss.channel</field>
            <field name="message_type">comment</field>
            <field name="res_id" ref="us_assistant.mail_channel_assistant"/>
            <field name="body"><![CDATA[<p>Hello! How's it going?</p>]]></field>
            <field name="author_id" ref="gpt_assistant_1"/>
            <field name="subtype_id" ref="mail.mt_comment"/>
        </record>

        <record id="mail_message_3" model="mail.message">
            <field name="model">discuss.channel</field>
            <field name="message_type">comment</field>
            <field name="res_id" ref="us_assistant.mail_channel_assistant"/>
            <field name="body"><![CDATA[<p>Give an answer. What is the distance from the Earth to the sun?</p>]]></field>
            <field name="author_id" ref="gpt_demo_partner_1"/>
            <field name="subtype_id" ref="mail.mt_comment"/>
        </record>

        <record id="mail_message_4" model="mail.message">
            <field name="model">discuss.channel</field>
            <field name="message_type">comment</field>
            <field name="res_id" ref="us_assistant.mail_channel_assistant"/>
            <field name="body"><![CDATA[<p>The average distance from the Earth to the Sun is about 93 million miles, which is roughly 150 million kilometers. This distance is also known as one astronomical unit (AU).</p>]]></field>
            <field name="author_id" ref="gpt_assistant_1"/>
            <field name="subtype_id" ref="mail.mt_comment"/>
        </record>
    </data>
</odoo>